{
  "manifest_version": 3,
  "name": "AI Chat outline",
  "version": "1.5.2",
  "description": "在侧面板中显示网页大纲，支持快速导航",
  "permissions": [
    "sidePanel", 
    "activeTab", 
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.deepseek.com/*",
    "*://*.yuanbao.tencent.com/*",
    "*://*.chatgpt.com/*",
    "*://*.gemini.google.com/*",
    "*://*.grok.com/*",
    "*://*.doubao.com/*",
    "*://*.kimi.com/*",
    "*://*.kimi.moonshot.cn/*"
  ],
  "side_panel": {
    "default_path": "src/core/sidepanel.html"
  },
  "background": {
    "service_worker": "src/core/background.js"
  },
  "icons": {
    "48": "public/assets/icon48.png",
    "128": "public/assets/icon128.png"
  },
  "action": {
    "default_icon": {
      "48": "public/assets/icon48.png",
      "128": "public/assets/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "打开/关闭大纲侧边栏"
    },
    "toggle_outline": {
      "suggested_key": {
        "default": "Alt+O",
        "mac": "Alt+O"
      },
      "description": "展开/折叠所有大纲项"
    },
    "next_heading": {
      "suggested_key": {
        "default": "Alt+J",
        "mac": "Alt+J"
      },
      "description": "跳转到下一个标题"
    },
    "prev_heading": {
      "suggested_key": {
        "default": "Alt+K",
        "mac": "Alt+K"
      },
      "description": "跳转到上一个标题"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/config/selectors.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
